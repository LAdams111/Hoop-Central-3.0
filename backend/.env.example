PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hoopcentral

# Comma-separated origins (Railway frontend URL + local dev)
CORS_ORIGINS=http://localhost:5173,https://your-frontend.up.railway.app

# JWT for admin sessions (generate a long random string in production)
JWT_SECRET=change-me-in-production

# Option A: bcrypt hash of admin password (recommended for production)
# ADMIN_PASSWORD_HASH=

# Option B: plain password (dev only — do not use in production)
# ADMIN_PASSWORD=changeme

# Scraper ingest: POST /api/ingest/players with header X-API-Key
# INGEST_API_KEY=
